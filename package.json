{
  "name": "lol-spell-overlay",
  "version": "0.1.0",
  "description": "LoL 적 소환사 스펠 쿨다운 오버레이 (수동 클릭 방식)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.lolspelloverlay.app",
    "productName": "LoL Spell Timer",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css"
    ],
    "win": {
      "target": ["portable", "zip"]
    },
    "portable": {
      "artifactName": "LoL-Spell-Timer.exe"
    }
  }
}